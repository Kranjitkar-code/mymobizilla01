import express from "express";
import bodyParser from "body-parser";
import cors from "cors";
import { appendRow, getHeaders, createHeaders } from "./sheets.js";
import path from "path";
import { fileURLToPath } from "url";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const app = express();
const PORT = process.env.PORT || 5000;

// Middleware
app.use(bodyParser.json());
app.use(cors());

// Serve static files from the React app build directory
app.use(express.static(path.join(__dirname, "../../dist")));

// Helper function to ensure headers exist
async function ensureHeaders() {
  try {
    const headers = await getHeaders();
    if (!headers || headers.length === 0) {
      // Create default headers if none exist
      const defaultHeaders = ["Timestamp", "Name", "Email", "ServiceType", "Details"];
      await createHeaders(defaultHeaders);
      console.log("Default headers created in Google Sheet");
      return defaultHeaders;
    }
    return headers;
  } catch (error) {
    console.log("Could not verify headers, creating default ones");
    const defaultHeaders = ["Timestamp", "Name", "Email", "ServiceType", "Details"];
    await createHeaders(defaultHeaders);
    return defaultHeaders;
  }
}

// POST endpoint to submit form data
app.post("/submit", async (req, res) => {
  try {
    const { name, email, serviceType, details, ...additionalFields } = req.body;
    const timestamp = new Date().toISOString();

    // Ensure headers exist
    const headers = await ensureHeaders();
    
    // Create row data based on existing headers + any new fields
    const rowData = [timestamp, name, email, serviceType, details];
    
    // Add any additional fields that aren't in the default set
    const additionalFieldNames = Object.keys(additionalFields);
    for (const fieldName of additionalFieldNames) {
      // If this is a new field, we might want to add it as a new column
      // For now, we'll just add the value to the row
      rowData.push(additionalFields[fieldName]);
    }

    await appendRow(rowData);

    res.status(200).json({ 
      success: true, 
      message: "Form submitted successfully!",
      data: { name, email, serviceType, details, ...additionalFields }
    });
  } catch (err) {
    console.error("Error saving form data:", err);
    res.status(500).json({ 
      success: false, 
      message: "Error saving form data",
      error: err.message 
    });
  }
});

// Health check endpoint
app.get("/health", (req, res) => {
  res.status(200).json({ 
    success: true, 
    message: "Google Forms backend is running",
    timestamp: new Date().toISOString()
  });
});

// Serve React app for any non-API routes
app.get("*", (req, res) => {
  res.sendFile(path.join(__dirname, "../../dist/index.html"));
});

app.listen(PORT, () => {
  console.log(`Google Forms backend server running on http://localhost:${PORT}`);
});

export default app;