# Mobizilla Nepal Configuration
VITE_APP_NAME="Mobizilla Nepal"
VITE_APP_URL="https://mymobizilla.com"
VITE_CURRENCY_CODE="NPR"
VITE_CURRENCY_SYMBOL="₨"
VITE_PHONE_PREFIX="+977"
VITE_TAX_PERCENT="13"
VITE_CONTACT_PHONE_1="+977-1-5354999"
VITE_CONTACT_PHONE_2="+977-9801018203"
VITE_CONTACT_ADDRESS="Ratna Plaza, New Road, Kathmandu 44600, Nepal"
VITE_CONTACT_EMAIL="info@mymobizilla.com"
VITE_BUSINESS_HOURS="10:00 AM – 7:00 PM, Sunday–Friday"

# WordPress Configuration
NEXT_PUBLIC_WORDPRESS_URL=http://your-wordpress-site.com/wp-json
JWT_AUTH_SECRET=your-jwt-secret-key
JWT_AUTH_ISSUER=mobizilla

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_SANCTUM_URL=http://localhost:8000/sanctum/csrf-cookie

# Twilio Configuration
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token
VITE_TWILIO_PHONE_NUMBER=your_twilio_phone_number

# SendGrid Configuration
VITE_SENDGRID_API_KEY=your_sendgrid_api_key

# Development
NODE_ENV=development
